SHOPIFY_API_KEY="YOUR_SHOPIFY_API_KEY"
SHOPIFY_API_SECRET="YOUR_SHOPIFY_SECRET"
HOST="YOUR_TUNNEL_URL"
SHOP="my-shop-name.myshopify.com"
SCOPES=write_products
MONGODB_URI="mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/NameZShopify?retryWrites=true&w=majority"
EBAY_CLIENT_ID="YOUR_EBAY_APP_ID"
EBAY_CLIENT_SECRET="YOUR_EBAY_CERT_ID"

# Optional: email yourself when a store installs the app (Gmail)
# 1. Use a Gmail account, enable 2FA, then create an App Password: https://myaccount.google.com/apppasswords
# 2. Set GMAIL_USER and GMAIL_APP_PASSWORD; set INSTALL_NOTIFY_EMAIL to the address to receive the notification (can be the same or another inbox).
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
INSTALL_NOTIFY_EMAIL=""
# Optional: admin dashboard protection
ADMIN_API_KEY=""

# Optional: alert emails
ALERT_EMAIL_FROM=""
ALERT_EMAIL_TO=""
